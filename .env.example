# Copy to .env for local development.
# In production these are Fly secrets — set by deploy.sh, never committed.

# Public URL (used in OAuth redirects and approval links)
PUBLIC_URL=http://localhost:8080

# Dashboard password
APP_PASSWORD=changeme

# Session cookie signing key — generate: openssl rand -hex 32
SESSION_SECRET=

# Postgres connection string (auto-set in prod by fly postgres attach)
DATABASE_URL=

# Corsair master encryption key — generate: openssl rand -base64 32
CORSAIR_KEK=

# Shared key between control server and runtime — generate: openssl rand -hex 32
CONTROL_API_KEY=
